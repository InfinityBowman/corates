{
  "name": "corates",
  "version": "0.0.1",
  "private": true,
  "description": "Cloudflare Workers/Durable Objects web app",
  "keywords": [
    "cloudflare",
    "durable-objects",
    "react",
    "workers"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "author": "Jacob Maynard",
  "type": "module",
  "scripts": {
    "kill-ports": "for port in 5173 8787 8788 3010 8080 9229 9230 9231; do lsof -ti:$port | xargs kill -9 2>/dev/null; done || true",
    "dev": "pnpm --filter web dev",
    "build": "pnpm --recursive run build",
    "build:web": "pnpm --filter web run build",
    "deploy": "pnpm --filter web run deploy",
    "deploy:reset:workers": "pnpm --filter workers run db:reset:prod",
    "clear-workers": "pnpm --filter workers run clear-workers",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:ui": "pnpm --filter web test",
    "test": "pnpm --recursive run test",
    "typecheck": "pnpm --recursive run typecheck",
    "logs": "pnpm --filter workers run logs",
    "deps:check": "pnpm -r outdated",
    "deps:up": "pnpm -r up",
    "deps:up:latest": "pnpm -r up --latest",
    "user:make-admin:prod": "pnpm --filter web run user:make-admin:prod",
    "user:make-admin:local": "pnpm --filter web run user:make-admin:local",
    "loc": "node ./scripts/loc-report.mjs",
    "docs": "pnpm --filter @corates/docs dev",
    "docs:build": "pnpm --filter @corates/docs build",
    "docs:preview": "pnpm --filter @corates/docs preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.1",
    "eslint": "^9.39.4",
    "eslint-plugin-drizzle": "^0.2.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.9.5",
    "typescript-eslint": "^8.58.0",
    "wrangler": "^4.81.0"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.26.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
