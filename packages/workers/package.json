{
  "name": "@corates/workers",
  "version": "0.0.1",
  "private": true,
  "description": "Library workspace: Durable Objects, commands, and lib helpers consumed by packages/web. No longer deploys.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "exports": {
    "./auth": {
      "types": "./auth.d.ts",
      "default": "./src/auth/session-helper.ts"
    },
    "./durable-objects": {
      "types": "./durable-objects.d.ts",
      "default": "./src/durable-objects/index.ts"
    },
    "./queue": {
      "types": "./queue.d.ts",
      "default": "./src/queue.ts"
    },
    "./project-sync": "./src/lib/project-sync.ts",
    "./project-doc-id": "./src/lib/project-doc-id.ts",
    "./email-templates": "./src/auth/emailTemplates.ts",
    "./auth-config": "./src/auth/config.ts",
    "./auth-admin": "./src/auth/admin.ts",
    "./commands/invitations": "./src/commands/invitations/index.ts",
    "./commands/projects": "./src/commands/projects/index.ts",
    "./commands/members": "./src/commands/members/index.ts",
    "./commands/billing": "./src/commands/billing/index.ts",
    "./stripe": "./src/lib/stripe.ts",
    "./billing-resolver": "./src/lib/billingResolver.ts",
    "./quota-transaction": "./src/lib/quotaTransaction.ts",
    "./constants": "./src/config/constants.ts",
    "./ssrf-protection": "./src/lib/ssrf-protection.ts",
    "./media-files": "./src/lib/media-files.ts",
    "./policies/projects": "./src/policies/projects.ts",
    "./policies": "./src/policies/index.ts",
    "./notify": "./src/lib/notify.ts",
    "./config/origins": "./src/config/origins.ts",
    "./logger": "./src/lib/logger.ts"
  },
  "scripts": {
    "test": "pnpm db:generate:test && vitest run",
    "test:watch": "vitest",
    "build": "pnpm --filter @corates/shared build",
    "db:generate": "drizzle-kit generate",
    "db:generate:test": "node ./scripts/generate-test-sql.mjs",
    "db:migrate": "y | wrangler d1 migrations apply corates-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply corates-db-prod --remote --env production",
    "db:setup:prod": "wrangler d1 migrations apply corates-db-prod --remote --env production",
    "db:reset:prod": "node ./scripts/reset-db-prod.mjs",
    "user:make-admin:local": "node ./scripts/make-admin-local.mjs",
    "user:make-admin:prod": "node ./scripts/make-admin-prod.mjs",
    "user:create-orcid:local": "node ./scripts/create-test-orcid-user.mjs",
    "stripe:setup": "node ./scripts/setup-stripe-test.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "studio": "drizzle-kit studio",
    "localflare": "localflare"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.0",
    "@corates/db": "workspace:*",
    "@corates/shared": "workspace:*",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "evlog": "^2.13.0",
    "lib0": "^0.2.117",
    "postmark": "^4.0.7",
    "stripe": "^20.4.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@vitest/runner": "^4.1.3",
    "@vitest/snapshot": "^4.1.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "localflare": "^0.5.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.2",
    "wrangler": "^4.81.0"
  }
}
