{
  "name": "@corates/workers",
  "version": "0.0.1",
  "private": true,
  "description": "Cloudflare Workers with Durable Objects",
  "license": "PolyForm-Noncommercial-1.0.0",
  "main": "src/index.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "concurrently \"wrangler dev\" \"pnpm build:rpc:watch\" --names wrangler,rpc --prefix-colors blue,green",
    "deploy": "pnpm --filter shared build && wrangler deploy --env production",
    "tail": "wrangler tail",
    "test": "pnpm db:generate:test && vitest run",
    "test:watch": "vitest",
    "build": "pnpm --filter @corates/shared build",
    "logs": "pnpm wrangler tail corates-workers-prod",
    "clear-workers": "rm -rf .wrangler/state && pnpm run db:migrate",
    "db:generate": "drizzle-kit generate",
    "db:generate:test": "node ./scripts/generate-test-sql.mjs",
    "db:migrate": "y | wrangler d1 migrations apply corates-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply corates-db-prod --remote --env production",
    "db:setup:prod": "wrangler d1 migrations apply corates-db-prod --remote --env production",
    "db:reset:prod": "node ./scripts/reset-db-prod.mjs",
    "user:make-admin:local": "node ./scripts/make-admin-local.mjs",
    "user:make-admin:prod": "node ./scripts/make-admin-prod.mjs",
    "user:create-orcid:local": "node ./scripts/create-test-orcid-user.mjs",
    "stripe:setup": "node ./scripts/setup-stripe-test.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:rpc": "tsc -p tsconfig.rpc.json",
    "build:rpc:watch": "tsc -p tsconfig.rpc.json --watch --preserveWatchOutput",
    "studio": "drizzle-kit studio",
    "localflare": "localflare"
  },
  "dependencies": {
    "@better-auth/stripe": "^1.6.0",
    "@corates/db": "workspace:*",
    "@corates/shared": "workspace:*",
    "@hono/zod-openapi": "^1.2.4",
    "@sentry/cloudflare": "^10.47.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.12",
    "lib0": "^0.2.117",
    "postmark": "^4.0.7",
    "stripe": "^20.4.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.30",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.2",
    "@cloudflare/workers-types": "^4.20260405.1",
    "@vitest/runner": "^4.1.3",
    "@vitest/snapshot": "^4.1.3",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.4.1",
    "drizzle-kit": "^0.31.10",
    "localflare": "^0.5.0",
    "typescript": "^5.9.3",
    "vitest": "4.1.2",
    "wrangler": "^4.81.0"
  }
}
