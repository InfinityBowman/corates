# Copy to .env for local development.
#
# For the Stripe webhook secret, get it from:
#   stripe listen --forward-to http://localhost:8788/api/billing/purchases/webhook
# Then copy the `whsec_...` value shown in the CLI output.
#
# STRIPE_SECRET_KEY can be the same test-mode `sk_test_...` key used by packages/workers.

STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET_PURCHASES=whsec_...
