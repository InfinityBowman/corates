{
  "name": "web",
  "version": "1.0.0",
  "private": true,
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "module",
  "scripts": {
    "dev": "portless corates vite dev",
    "build": "NODE_OPTIONS='--max-old-space-size=6144' vite build",
    "build:prod": "pnpm --filter @corates/shared --filter @corates/db build && CLOUDFLARE_ENV=production pnpm run build",
    "build:staging": "pnpm --filter @corates/shared --filter @corates/db build && CLOUDFLARE_ENV=staging pnpm run build",
    "preview": "vite preview",
    "deploy": "CLOUDFLARE_ENV=production pnpm run build:prod && pnpm run db:migrate:prod && wrangler deploy",
    "deploy:staging": "CLOUDFLARE_ENV=staging pnpm run build:staging && pnpm run db:migrate:staging && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "y | wrangler d1 migrations apply corates-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply corates-db-prod --remote --env production --config wrangler.jsonc",
    "db:migrate:staging": "wrangler d1 migrations apply corates-db-staging --remote --env staging --config wrangler.jsonc",
    "db:reset:prod": "node ./scripts/reset-db-prod.mjs",
    "dev:pdfs": "node ./scripts/fetch-dev-pdfs.mjs",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run test:unit && pnpm run test:server",
    "test:unit": "vitest run --config vitest.config.ts --reporter=verbose",
    "test:watch": "vitest --config vitest.config.ts",
    "test:server": "pnpm run db:generate:test && vitest run --config vitest.server.config.ts",
    "pretest:dev": "lsof -ti:3010 | xargs kill -9 2>/dev/null || true",
    "dev:test": "concurrently -k -n web,stripe -c blue,yellow \"APP_URL=http://localhost:3010 AUTH_BASE_URL=http://localhost:3010 vite dev --mode e2e --config vite.config.e2e.ts\" \"stripe listen --forward-to http://localhost:3010/api/auth/stripe/webhook\"",
    "test:e2e": "playwright test",
    "db:generate:test": "node ./scripts/generate-test-sql.mjs",
    "user:make-admin:local": "node ./scripts/make-admin-local.mjs",
    "user:make-admin:prod": "node ./scripts/make-admin-prod.mjs"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@corates/db": "workspace:*",
    "@corates/shared": "workspace:*",
    "@corates/workers": "workspace:*",
    "@embedpdf/core": "^2.14.4",
    "@embedpdf/engines": "^2.14.4",
    "@embedpdf/models": "^2.14.4",
    "@embedpdf/pdfium": "^2.14.4",
    "@embedpdf/plugin-annotation": "^2.14.4",
    "@embedpdf/plugin-capture": "^2.14.4",
    "@embedpdf/plugin-document-manager": "^2.14.4",
    "@embedpdf/plugin-export": "^2.14.4",
    "@embedpdf/plugin-fullscreen": "^2.14.4",
    "@embedpdf/plugin-history": "^2.14.4",
    "@embedpdf/plugin-i18n": "^2.14.4",
    "@embedpdf/plugin-interaction-manager": "^2.14.4",
    "@embedpdf/plugin-pan": "^2.14.4",
    "@embedpdf/plugin-print": "^2.14.4",
    "@embedpdf/plugin-redaction": "^2.14.4",
    "@embedpdf/plugin-render": "^2.14.4",
    "@embedpdf/plugin-rotate": "^2.14.4",
    "@embedpdf/plugin-scroll": "^2.14.4",
    "@embedpdf/plugin-search": "^2.14.4",
    "@embedpdf/plugin-selection": "^2.14.4",
    "@embedpdf/plugin-spread": "^2.14.4",
    "@embedpdf/plugin-thumbnail": "^2.14.4",
    "@embedpdf/plugin-tiling": "^2.14.4",
    "@embedpdf/plugin-ui": "^2.14.4",
    "@embedpdf/plugin-viewport": "^2.14.4",
    "@embedpdf/plugin-zoom": "^2.14.4",
    "@fontsource-variable/geist": "^5.2.9",
    "@sentry/cloudflare": "^10.62.0",
    "@sentry/react": "^10.62.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-router": "^1.170.16",
    "@tanstack/react-start": "^1.168.26",
    "@tanstack/react-table": "^8.21.3",
    "@tldraw/state": "4.5.10",
    "@tldraw/state-react": "4.5.10",
    "better-auth": "^1.6.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "countup.js": "^2.10.0",
    "d3": "^7.9.0",
    "dexie": "^4.4.4",
    "drizzle-orm": "^0.45.2",
    "immer": "^11.1.8",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "lucide-react": "^1.22.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.9.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "stripe": "^22.3.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "y-dexie": "^4.4.0",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.42.3",
    "@cloudflare/vitest-pool-workers": "^0.18.4",
    "@cloudflare/workers-types": "^4.20260628.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/router-plugin": "^1.168.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/google.picker": "^0.0.52",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.110.0"
  }
}
