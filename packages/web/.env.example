# Copy to .env and .env.production and set appropriate values
VITE_API_URL="http://corates.localhost:1355"
VITE_PUBLIC_APP_URL="http://corates.localhost:1355"

# URL Base Path
VITE_BASEPATH="/"

# For Google Picker integration
VITE_GOOGLE_PICKER_API_KEY="your-google-picker-api-key-here"
VITE_GOOGLE_PICKER_APP_ID="your-google-project-number"

# Sentry error monitoring (optional)
# Get DSN from https://sentry.io/settings/projects/YOUR_PROJECT/keys/
VITE_SENTRY_DSN=""

# Set to "true" to send errors to Sentry in development
VITE_SENTRY_DEV=false

# Server secrets template

# Auth configuration (REQUIRED)
AUTH_SECRET=generate-a-very-long-random-secret-key-at-least-64-characters-long

# Email configuration
EMAIL_FROM=your-email@gmail.com

# Postmark Server Token
POSTMARK_SERVER_TOKEN=your-postmark-server-token

# URL to main corates web app
APP_URL=http://corates.localhost:1355

# Email testing (set to true to send real emails)
# SEND_EMAILS_IN_DEV=false

GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

ORCID_CLIENT_ID=your_client_id
ORCID_CLIENT_SECRET=your_client_secret

ADMIN_EMAIL=you@example.com

# Stripe Test Mode Configuration
STRIPE_SECRET_KEY=sk_test_...your_test_secret_key...

# Webhook secrets (from Stripe CLI when running locally)
STRIPE_WEBHOOK_SECRET_AUTH=whsec_...AUTH
STRIPE_WEBHOOK_SECRET_PURCHASES=whsec_...PURCHASES

# Test Price IDs (create these in Stripe Dashboard > Products > Test mode)
STRIPE_PRICE_ID_STARTER_TEAM_MONTHLY=price_...STARTER_TEAM_MONTHLY
STRIPE_PRICE_ID_STARTER_TEAM_YEARLY=price_...STARTER_TEAM_YEARLY
STRIPE_PRICE_ID_TEAM_MONTHLY=price_...TEAM_MONTHLY
STRIPE_PRICE_ID_TEAM_YEARLY=price_...TEAM_YEARLY
STRIPE_PRICE_ID_UNLIMITED_TEAM_MONTHLY=price_...UNLIMITED_TEAM_MONTHLY
STRIPE_PRICE_ID_UNLIMITED_TEAM_YEARLY=price_...UNLIMITED_TEAM_YEARLY
STRIPE_PRICE_ID_SINGLE_PROJECT=price_...SINGLE_PROJECT
